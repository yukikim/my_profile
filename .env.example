# docker-compose.ymlのPostgreSQL設定と一致させ、host上のNext.js・MCPから共用します。
DATABASE_URI=postgres://my_profile:my_profile_password@localhost:5432/my_profile
# Payloadの署名・暗号化に使うため、本番では十分に長いランダム値へ置き換えます。
PAYLOAD_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000
TEMPLATE=profile
# seed用認証情報です。本番管理者の実パスワードはこのexampleへ記録しません。
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password123
SEED_ADMIN_NAME=Admin User

# 問い合わせ通知メールを有効にするときだけ設定します。
GMAIL_USER=your_gmail_user@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
